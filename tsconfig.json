{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noImplicitAny": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["main.tsx", "App.tsx", "types.ts", "services/**/*.ts", "pages/**/*.tsx", "components/**/*.tsx", "contexts/**/*.tsx", "hooks/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist", ".vercel", "src"]
}